{
	"name": "project-c",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig tsconfig.json --watch",
		"test": "vitest",
		"lint": "prettier --plugin-search-dir project-c --check . && eslint .",
		"format": "prettier --plugin-search-dir project-c --write ."
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@typescript-eslint/eslint-plugin": "8.58.0",
		"@typescript-eslint/parser": "8.58.0",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "3.17.0",
		"prettier": "3.8.1",
		"prettier-plugin-svelte": "3.5.1",
		"svelte": "5.55.1",
		"svelte-check": "4.4.6",
		"tslib": "2.8.1",
		"typescript": "5.9.3",
		"vite": "^8.0.3",
		"vitest": "^4.1.2"
	},
	"type": "module",
	"dependencies": {
		"@egjs/svelte-grid": "^1.18.0"
	}
